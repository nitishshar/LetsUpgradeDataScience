## 7. Rule Refinement Layer

### 7.1 Rule Refinement Pipeline (Orchestrator)

```java
// pipeline/impl/RuleRefinementPipeline.java
@Component
@Slf4j
public class RuleRefinementPipeline implements Pipeline<RuleIntakeRequest, PipelineResult> {

    private final RuleIntakeService intakeService;
    private final CheckpointEvaluationEngine checkpointEngine;
    private final RefinementFeedbackBuilder feedbackBuilder;
    private final LlmRuleRefiner refiner;
    private final TraceService traceService;

    @Override
    public PipelineType type() { return PipelineType.RULE_REFINEMENT; }

    @Override
    public PipelineResult execute(PipelineContext<RuleIntakeRequest> ctx) {
        var trace = traceService.start(PipelineType.RULE_REFINEMENT, ctx.correlationId());

        try {
            // ── Stage 1: Rule Intake ──────────────────────────────────────
            log.info("[{}] Stage 1: Rule intake", ctx.correlationId());
            var rule = intakeService.ingest(ctx.input());
            traceService.record(trace, TraceEvent.intake(rule));

            // ── Stage 2: Checkpoint Evaluation ───────────────────────────
            log.info("[{}] Stage 2: Checkpoint evaluation for rule {}", ctx.correlationId(), rule.id());
            var checkpointReport = checkpointEngine.evaluate(rule);
            var feedback         = feedbackBuilder.build(rule, checkpointReport);
            traceService.record(trace, TraceEvent.checkpoints(checkpointReport));

            log.info("[{}] Checkpoint result: {}/{} passed, blockingFailures={}",
                ctx.correlationId(),
                checkpointReport.passed(), checkpointReport.totalChecked(),
                checkpointReport.hasBlockingFailures());

            // ── Stage 3: Rule Refinement (LLM) ───────────────────────────
            log.info("[{}] Stage 3: LLM refinement (feedbackPresent={})",
                ctx.correlationId(), feedback.hasFailures());
            var refinedRule = refiner.refine(rule, feedback, ctx.modelOptions());
            traceService.record(trace, TraceEvent.refinement(refinedRule));

            // ── Stage 4: Output ───────────────────────────────────────────
            traceService.succeed(trace);
            return PipelineResult.success(refinedRule, checkpointReport, trace.traceId());

        } catch (Exception ex) {
            traceService.fail(trace, ex);
            throw new PipelineExecutionException("Rule refinement pipeline failed", ex);
        }
    }
}
```

### 7.2 LLM Rule Refiner

```java
// refinement/LlmRuleRefiner.java
@Component
public class LlmRuleRefiner implements RuleRefiner {

    private final PromptAssembler promptAssembler;
    private final LlmRouter router;
    private final JsonResponseParser responseParser;
    private final RefinedRuleMapper ruleMapper;

    @Override
    public Rule refine(Rule rule, RefinementFeedback feedback, ModelOptions options) {
        // Select template based on whether checkpoint failures exist
        var templateId = feedback.hasFailures()
            ? "rule-refinement-with-feedback"
            : "rule-refinement";

        var context = PromptContext.builder()
            .templateId(templateId)
            .variable("rule",     rule)
            .variable("feedback", feedback)
            .build();

        var compiled = promptAssembler.assemble(context);
        var raw      = router.route(RoutingContext.from(options))
                             .complete(LlmRequest.from(compiled, options));

        var parsed = responseParser.parse(raw.content(),
                         ResponseSchema.json(RefinedRuleOutput.class));

        return ruleMapper.apply(rule, parsed.payload());
    }
}
```


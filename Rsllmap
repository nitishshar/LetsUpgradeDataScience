## 5. Core Domain Model

### 5.1 Rule

```java
// domain/rule/Rule.java
public record Rule(
    UUID id,
    String name,
    String description,
    String rawContent,          // original as submitted
    String canonicalContent,    // standardized by RuleIntakeService
    RuleStatus status,          // DRAFT → ACTIVE | REFINEMENT_FAILED
    int version,
    String enterpriseId,        // used for ENTERPRISE checkpoint scope resolution
    String domainId,            // used for DOMAIN checkpoint scope resolution
    Map<String, Object> metadata,
    Instant createdAt,
    Instant updatedAt
) {
    public Rule {
        Objects.requireNonNull(id);
        Objects.requireNonNull(canonicalContent);
        if (version < 1) throw new IllegalArgumentException("version must be >= 1");
    }
}

public enum RuleStatus {
    DRAFT,              // just ingested, not yet evaluated or refined
    ACTIVE,             // successfully refined and output to caller
    REFINEMENT_FAILED   // LLM could not produce a valid refinement
}
```

### 5.2 Checkpoint Domain Objects

```java
// domain/checkpoint/CheckpointDefinition.java
public record CheckpointDefinition(
    String id,
    String name,
    String description,
    CheckpointScope scope,           // GENERIC | ENTERPRISE | DOMAIN | RULE
    CheckpointSeverity severity,     // BLOCKING | WARNING
    String scopeOwnerId,             // null=GENERIC; enterpriseId; domainId; or ruleId
    String evaluationType,           // LENGTH | REGEX | CONTAINS | LLM_EVAL | CUSTOM_EXPR
    Map<String, Object> parameters,
    boolean active,
    int evaluationOrder
) {}

// domain/checkpoint/CheckpointFailure.java
public record CheckpointFailure(
    String checkpointId,
    String checkpointName,
    CheckpointScope scope,
    CheckpointSeverity severity,
    String failureReason,            // plain language — fed directly to LLM
    String evaluatedValue            // the snippet that triggered the failure
) {}

// domain/checkpoint/CheckpointEvaluationReport.java
public record CheckpointEvaluationReport(
    UUID ruleId,
    int totalChecked,
    int passed,
    int failed,
    boolean hasBlockingFailures,

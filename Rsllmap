```java
// prompt/assembler/DefaultPromptAssembler.java
@Service
public class DefaultPromptAssembler implements PromptAssembler {

    private final TemplateRegistry templateRegistry;
    private final List<ContextEnricher> enrichers;

    @Override
    public CompiledPrompt assemble(PromptContext context) {
        // Enrich context through the enricher chain (metadata, system config, etc.)
        var enriched = enrichers.stream()
            .reduce(context, (ctx, e) -> e.enrich(ctx), (a, b) -> b);

        var template = templateRegistry.get(enriched.templateId());
        return new CompiledPrompt(
            template.renderSystem(enriched.variables()),
            template.renderUser(enriched.variables()),
            enriched.traceId()
        );
    }
}

### 10.3 JSON Response Parser

```java
// response/parser/JsonResponseParser.java
@Component
public class JsonResponseParser implements ResponseParser {

    private static final Pattern JSON_FENCE =
        Pattern.compile("```(?:json)?\\s*(\\{.*?})\\s*```", Pattern.DOTALL);

    @Override
    public <T> StructuredResponse<T> parse(String raw, ResponseSchema<T> schema) {
        var cleaned = extractJson(raw);
        var errors  = schemaValidator.validate(cleaned, schema);
        T payload   = mapper.readValue(cleaned, schema.targetType());
        return new StructuredResponse<>(payload, raw, errors.isEmpty(), errors, Map.of());
    }

    private String extractJson(String raw) {
        var m = JSON_FENCE.matcher(raw);
        return m.find() ? m.group(1).strip() : raw.strip();
    }
}

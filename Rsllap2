### 6.2 Checkpoint Loader

```python
# checkpoint/loader/checkpoint_loader.py
import json
from pathlib import Path
from llm_service.domain.checkpoint.checkpoint_definition import CheckpointDefinition


class CheckpointLoader:

    def __init__(self, config_directory: str) -> None:
        self._directory = Path(config_directory)

    def load_all(self) -> list[CheckpointDefinition]:
        checkpoints = []
        for json_file in self._directory.rglob("*.json"):
            data = json.loads(json_file.read_text(encoding="utf-8"))
            checkpoints.append(CheckpointDefinition(**data))
        return [cp for cp in checkpoints if cp.active]
```


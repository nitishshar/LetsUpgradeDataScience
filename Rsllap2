### 7.1 Rule Refinement Pipeline (Orchestrator)

```python
# pipeline/impl/rule_refinement_pipeline.py
import structlog
from llm_service.domain.pipeline.pipeline import Pipeline
from llm_service.domain.pipeline.pipeline_context import PipelineContext
from llm_service.domain.pipeline.pipeline_result import PipelineResult
from llm_service.domain.pipeline.pipeline_type import PipelineType
from llm_service.intake.rule_intake_service import RuleIntakeService
from llm_service.checkpoint.evaluator.checkpoint_evaluation_engine import CheckpointEvaluationEngine
from llm_service.checkpoint.feedback.refinement_feedback_builder import RefinementFeedbackBuilder
from llm_service.refinement.llm_rule_refiner import LlmRuleRefiner
from llm_service.trace.trace_service import TraceService

log = structlog.get_logger()


class RuleRefinementPipeline(Pipeline):

    pipeline_type = PipelineType.RULE_REFINEMENT

    def __init__(
        self,
        intake_service: RuleIntakeService,
        checkpoint_engine: CheckpointEvaluationEngine,
        feedback_builder: RefinementFeedbackBuilder,
        refiner: LlmRuleRefiner,
        trace_service: TraceService,
    ) -> None:
        self._intake     = intake_service
        self._checkpoints = checkpoint_engine
        self._feedback   = feedback_builder
        self._refiner    = refiner
        self._trace      = trace_service

    async def execute(self, context: PipelineContext) -> PipelineResult:
        trace = await self._trace.start(PipelineType.RULE_REFINEMENT, context.correlation_id)

        try:
            # ── Stage 1: Rule Intake ──────────────────────────────────────
            log.info("stage_1_intake", correlation_id=context.correlation_id)
            rule = await self._intake.ingest(context.input)
            await self._trace.record(trace, "RULE_INTAKE", {"rule_id": str(rule.id)})

            # ── Stage 2: Checkpoint Evaluation ────────────────────────────
            log.info("stage_2_checkpoint_evaluation", rule_id=str(rule.id))
            report   = await self._checkpoints.evaluate(rule)
            feedback = self._feedback.build(rule, report)
            await self._trace.record(trace, "CHECKPOINT_EVALUATION", {
                "total_checked": report.total_checked,
                "failed": report.failed,
                "has_blocking": report.has_blocking_failures,
            })

            log.info(
                "checkpoint_result",
                passed=report.passed,
                failed=report.failed,
                has_blocking=report.has_blocking_failures
            )

            # ── Stage 3: Rule Refinement (LLM) ────────────────────────────
            log.info("stage_3_llm_refinement", feedback_present=feedback.has_failures)
            refined_rule = await self._refiner.refine(rule, feedback, context.model_options)
            await self._trace.record(trace, "REFINEMENT_COMPLETE", {
                "version": refined_rule.version,
                "status": refined_rule.status.value,
            })

            # ── Stage 4: Output ───────────────────────────────────────────
            await self._trace.succeed(trace)
            return PipelineResult(
                success=True,
                refined_rule=refined_rule,
                checkpoint_report=report,
                trace_id=trace.trace_id,
            )

        except Exception as exc:
            await self._trace.fail(trace, exc)
            raise
```

### 7.2 LLM Rule Refiner

```python
# refinement/llm_rule_refiner.py
from llm_service.domain.rule.rule import Rule
from llm_service.domain.rule.refinement_feedback import RefinementFeedback
from llm_service.prompt.assembler.default_prompt_assembler import DefaultPromptAssembler
from llm_service.llm.router.llm_router import LlmRouter
from llm_service.response.parser.json_response_parser import JsonResponseParser
from llm_service.refinement.refined_rule_mapper import RefinedRuleMapper


class LlmRuleRefiner:

    def __init__(
        self,
        assembler: DefaultPromptAssembler,
        router: LlmRouter,
        parser: JsonResponseParser,
        mapper: RefinedRuleMapper,
    ) -> None:
        self._assembler = assembler
        self._router    = router
        self._parser    = parser
        self._mapper    = mapper

    async def refine(
        self, rule: Rule, feedback: RefinementFeedback, options
    ) -> Rule:
        template_id = (
            "rule_refinement_with_feedback"
            if feedback.has_failures
            else "rule_refinement"
        )

        context = {
            "template_id": template_id,
            "variables": {
                "rule": rule.model_dump(),
                "feedback": feedback.model_dump(),
            }
        }

        compiled = await self._assembler.assemble(context)
        client   = self._router.route(options)
        raw      = await client.complete(compiled)
        parsed   = self._parser.parse(raw.content, target_type=RefinedRuleOutput)

        return self._mapper.apply(rule, parsed.payload)

# checkpoint/evaluator/checkpoint_evaluator.py
from typing import Protocol
from llm_service.domain.checkpoint.checkpoint_definition import CheckpointDefinition
from llm_service.domain.checkpoint.checkpoint_result import CheckpointResult
from llm_service.domain.rule.rule import Rule


class CheckpointEvaluator(Protocol):
    evaluation_type: str

    async def evaluate(
        self, rule: Rule, checkpoint: CheckpointDefinition
    ) -> CheckpointResult: ...


# checkpoint/evaluator/length_evaluator.py
class LengthEvaluator:
    evaluation_type = "LENGTH"

    async def evaluate(self, rule: Rule, cp: CheckpointDefinition) -> CheckpointResult:
        field   = cp.parameters.get("field", "canonical_content")
        value   = getattr(rule, field, "")
        length  = len(value)
        min_len = cp.parameters.get("min_length")
        max_len = cp.parameters.get("max_length")

        if min_len and length < min_len:
            return CheckpointResult(
                passed=False,
                failure_reason=f"Content is {length} chars, minimum is {min_len}",
                evaluated_value=value[:100]
            )
        if max_len and length > max_len:
            return CheckpointResult(
                passed=False,
                failure_reason=f"Content is {length} chars, maximum is {max_len}",
                evaluated_value=value[:100]
            )
        return CheckpointResult(passed=True)


# checkpoint/evaluator/regex_evaluator.py
import re

class RegexEvaluator:
    evaluation_type = "REGEX"

    async def evaluate(self, rule: Rule, cp: CheckpointDefinition) -> CheckpointResult:
        field    = cp.parameters.get("field", "canonical_content")
        value    = getattr(rule, field, "")
        patterns = cp.parameters.get("prohibited_patterns", [])

        for pattern in patterns:
            match = re.search(pattern, value, re.IGNORECASE)
            if match:
                return CheckpointResult(
                    passed=False,
                    failure_reason=f"Contains prohibited term '{match.group()}'",
                    evaluated_value=match.group()
                )
        return CheckpointResult(passed=True)


# checkpoint/evaluator/contains_evaluator.py
class ContainsEvaluator:
    evaluation_type = "CONTAINS"

    async def evaluate(self, rule: Rule, cp: CheckpointDefinition) -> CheckpointResult:
        field        = cp.parameters.get("field", "canonical_content")
        value        = getattr(rule, field, "").lower()
        required     = cp.parameters.get("required_terms", [])
        min_matches  = cp.parameters.get("min_matches", 1)
        found        = [t for t in required if t.lower() in value]

        if len(found) < min_matches:
            return CheckpointResult(
                passed=False,
                failure_reason=(
                    f"No recognized term found. Expected at least {min_matches} of: "
                    f"{', '.join(required)}"
                ),
                evaluated_value=value[:100]
            )
        return CheckpointResult(passed=True)

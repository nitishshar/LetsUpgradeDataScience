from llm_service.domain.rule.rule import Rule


class CheckpointRegistry:

    def __init__(self, checkpoints: list[CheckpointDefinition]) -> None:
        self._checkpoints = checkpoints

    def resolve_for(self, rule: Rule) -> list[CheckpointDefinition]:
        """Return all applicable checkpoints for a rule, sorted by evaluation_order."""
        applicable = [
            cp for cp in self._checkpoints
            if self._applies(cp, rule)
        ]
        return sorted(applicable, key=lambda cp: cp.evaluation_order)

    def _applies(self, cp: CheckpointDefinition, rule: Rule) -> bool:
        match cp.scope:
            case CheckpointScope.GENERIC:
                return True
            case CheckpointScope.ENTERPRISE:
                return cp.scope_owner_id == rule.enterprise_id
            case CheckpointScope.DOMAIN:
                return cp.scope_owner_id == rule.domain_id
            case CheckpointScope.RULE:
                return cp.scope_owner_id == str(rule.id)
            case _:
                return False

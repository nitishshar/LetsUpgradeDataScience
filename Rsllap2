# llm/client/litellm_client.py
import litellm
from llm_service.llm.models.llm_request import LlmRequest
from llm_service.llm.models.llm_raw_response import LlmRawResponse


class LiteLlmClient:
    """
    Single client for OpenAI, Anthropic, Azure, Bedrock, etc.
    Provider is selected by the model string: "gpt-4o-mini", "claude-sonnet-4-20250514", etc.
    """
    provider_id = "litellm"

    async def complete(self, request: LlmRequest) -> LlmRawResponse:
        response = await litellm.acompletion(
            model=request.model,
            messages=[
                {"role": "system", "content": request.system_prompt},
                {"role": "user",   "content": request.user_prompt},
            ],
            temperature=request.temperature,
            max_tokens=request.max_tokens,
        )
        content = response.choices[0].message.content
        usage   = response.usage
        return LlmRawResponse(
            content=content,
            input_tokens=usage.prompt_tokens,
            output_tokens=usage.completion_tokens,
            model=response.model,
        )

    def is_available(self) -> bool:
        return True

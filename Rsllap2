### 6.6 Refinement Feedback Builder

```python
# checkpoint/feedback/refinement_feedback_builder.py
from llm_service.domain.checkpoint.checkpoint_evaluation_report import CheckpointEvaluationReport
from llm_service.domain.checkpoint.checkpoint_severity import CheckpointSeverity
from llm_service.domain.rule.refinement_feedback import RefinementFeedback
from llm_service.domain.rule.rule import Rule


class RefinementFeedbackBuilder:

    def build(
        self, rule: Rule, report: CheckpointEvaluationReport
    ) -> RefinementFeedback:
        if not report.has_blocking_failures:
            return RefinementFeedback.none(rule.id)

        blocking = [
            f for f in report.failures
            if f.severity == CheckpointSeverity.BLOCKING
        ]
        return RefinementFeedback(
            rule_id=rule.id,
            has_failures=True,
            failures=blocking,
            feedback_narrative=self._build_narrative(blocking)
        )

    def _build_narrative(self, failures) -> str:
        lines = [
            "The following data quality standards were not met. "
            "You MUST rewrite the rule to satisfy each one:\n"
        ]
        for i, f in enumerate(failures, 1):
            lines.append(
                f"{i}. [{f.scope.value}] {f.checkpoint_name}\n"
                f"   Issue: {f.failure_reason}\n"
                f"   Problematic value: \"{f.evaluated_value}\"\n"
            )
        return "\n".join(lines)

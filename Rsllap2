        ),
        CheckpointFailure(
            checkpoint_id="generic-min-length", checkpoint_name="Min Length",
            scope=CheckpointScope.GENERIC, severity=CheckpointSeverity.BLOCKING,
            failure_reason="Content is 8 chars, minimum is 20",
            evaluated_value="Do it."
        ),
    ]
    builder  = RefinementFeedbackBuilder()
    feedback = builder.build(draft_rule(), report_with_blocking_failures(failures))

    assert feedback.has_failures is True
    assert "Regulatory Language" in feedback.feedback_narrative
    assert "prohibited term 'should be'" in feedback.feedback_narrative
    assert "minimum is 20" in feedback.feedback_narrative

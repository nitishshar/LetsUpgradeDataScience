### 6.5 Checkpoint Evaluation Engine

```python
# checkpoint/evaluator/checkpoint_evaluation_engine.py
import asyncio
from datetime import datetime
from llm_service.domain.checkpoint.checkpoint_evaluation_report import CheckpointEvaluationReport
from llm_service.domain.checkpoint.checkpoint_failure import CheckpointFailure
from llm_service.domain.checkpoint.checkpoint_severity import CheckpointSeverity
from llm_service.domain.rule.rule import Rule
from llm_service.checkpoint.registry.checkpoint_registry import CheckpointRegistry
from llm_service.checkpoint.evaluator.checkpoint_evaluator import CheckpointEvaluator


class CheckpointEvaluationEngine:

    def __init__(
        self,
        registry: CheckpointRegistry,
        evaluators: list[CheckpointEvaluator]
    ) -> None:
        self._registry   = registry
        self._evaluators = {e.evaluation_type: e for e in evaluators}

    async def evaluate(self, rule: Rule) -> CheckpointEvaluationReport:
        applicable = self._registry.resolve_for(rule)

        # Run all evaluations concurrently
        tasks   = [self._run(rule, cp) for cp in applicable]
        results = await asyncio.gather(*tasks)

        failures = [r for r in results if r is not None]
        has_blocking = any(
            f.severity == CheckpointSeverity.BLOCKING for f in failures
        )

        return CheckpointEvaluationReport(
            rule_id=rule.id,
            total_checked=len(applicable),
            passed=len(applicable) - len(failures),
            failed=len(failures),
            has_blocking_failures=has_blocking,
            failures=failures,
            evaluated_at=datetime.utcnow()
        )

    async def _run(
        self, rule: Rule, cp
    ) -> CheckpointFailure | None:
        evaluator = self._evaluators.get(cp.evaluation_type)
        if not evaluator:
            return None
        result = await evaluator.evaluate(rule, cp)
        if not result.passed:
            return CheckpointFailure(
                checkpoint_id=cp.id,
                checkpoint_name=cp.name,
                scope=cp.scope,
                severity=cp.severity,
                failure_reason=result.failure_reason,
                evaluated_value=result.evaluated_value or ""
            )
        return None

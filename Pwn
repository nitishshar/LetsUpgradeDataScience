## Problem 2: Checkbox collapses form → step gets stuck

### What codegen generated (broken):
```ts
When('I check the "Residential" checkbox', async function(this: PwCraftWorld) {
  const cb = this.find.checkboxByLabel('Residential');
  await this.action.check(cb);
  await expect(cb).toBeChecked(); // ← WRONG: checkbox leaves DOM after click
});
```

### Why it gets stuck
After clicking, your app:
1. Marks form section A as collapsed (removes from DOM)
2. Renders form section B
3. The checkbox is inside section A → it's gone → isChecked() waits forever

### Fix pattern: assert the OUTCOME, not the clicked element

```ts
// PATTERN 1: New section appears after checkbox click
When('I check the "Residential" checkbox', async function(this: PwCraftWorld) {
  const smart = new SmartWaitHelper(this.page);
  await this.action.click(this.find.checkboxByLabel('Residential'));
  // Wait for whatever the DOM change is — don't assume
  await smart.forDomStability(3_000);
});

Then('the residential form should be visible', async function(this: PwCraftWorld) {
  // Assert on the RESULT of the action
  await this.assert.elementVisible(this.find.byTestId('residential-form'));
});
```

```ts
// PATTERN 2: You know what appears — combine into one step
When('I check "Include spouse" and the spouse section appears', async function(this: PwCraftWorld) {
  const smart = new SmartWaitHelper(this.page);
  await smart.forActionOutcome(
    () => this.action.click(this.find.checkboxByLabel('Include spouse')),
    this.find.byTestId('spouse-section'),    // what to wait for
    { hiddenLocator: this.find.byTestId('no-spouse-msg') } // what disappears
  );
});
```

```ts
// PATTERN 3: Multiple possible outcomes (success or error)
When('I submit the form', async function(this: PwCraftWorld) {
  const smart = new SmartWaitHelper(this.page);
  await this.action.click(this.find.byRole('button', { name: 'Submit' }));
  const outcome = await smart.forOneOf([
    this.page.locator('[data-testid="success-message"]'),
    this.page.locator('[data-testid="error-message"]'),
    this.page.locator('[data-testid="validation-errors"]'),
  ]);
  this.logger.info(`Submit outcome index: ${outcome}`);
});
```


### Step 3.7 — Generate Helper: `auth.helper.ts`

```typescript
// e2e/helpers/auth.helper.ts
import { Page, BrowserContext } from '@playwright/test';

export interface Credentials {
  username: string;
  password: string;
}

const DEFAULT_ADMIN: Credentials = {
  username: process.env.TEST_USER || 'admin@test.com',
  password: process.env.TEST_PASSWORD || 'TestPass123!',
};

export class AuthHelper {
  constructor(private page: Page) {}

  /** Full UI login flow */
  async loginViaUI(creds: Credentials = DEFAULT_ADMIN): Promise<void> {
    await this.page.goto('/login');
    await this.page.getByLabel('Email').fill(creds.username);
    await this.page.getByLabel('Password').fill(creds.password);
    await this.page.getByRole('button', { name: 'Login' }).click();
    await this.page.waitForURL(/dashboard|home/, { timeout: 10000 });
  }

  /** Fast API-based login — injects token to localStorage */
  async loginViaAPI(creds: Credentials = DEFAULT_ADMIN): Promise<void> {
    const response = await this.page.request.post('/api/auth/login', {
      data: { email: creds.username, password: creds.password },
    });
    const { token } = await response.json();
    await this.page.evaluate((t) => localStorage.setItem('auth_token', t), token);
  }

  async logout(): Promise<void> {
    await this.page.evaluate(() => localStorage.clear());
    await this.page.goto('/login');
  }

  async saveAuthState(context: BrowserContext, path = 'e2e/.auth/user.json'): Promise<void> {
    await context.storageState({ path });
  }
}
```


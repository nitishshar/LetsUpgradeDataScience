```typescript
// e2e/helpers/table.helper.ts
import { Page, Locator } from '@playwright/test';
import { expect } from '@playwright/test';

export class TableHelper {
  private table: Locator;

  constructor(private page: Page, tableSelector = '[data-testid="data-table"]') {
    this.table = page.locator(tableSelector);
  }

  async getRowCount(): Promise<number> {
    return this.table.locator('tbody tr').count();
  }

  async getCellText(row: number, col: number): Promise<string> {
    return this.table.locator('tbody tr').nth(row).locator('td').nth(col).innerText();
  }

  async clickRowAction(rowIndex: number, actionText: string): Promise<void> {
    const row = this.table.locator('tbody tr').nth(rowIndex);
    await row.locator(`button, a`).filter({ hasText: actionText }).click();
  }

  async sortByColumn(columnHeader: string): Promise<void> {
    await this.table.locator('th').filter({ hasText: columnHeader }).click();
  }

  async searchTable(searchText: string, searchSelector = '[data-testid="table-search"]'): Promise<void> {
    await this.page.locator(searchSelector).fill(searchText);
    await this.page.waitForTimeout(300); // debounce
  }

  async assertRowExists(cellText: string): Promise<void> {
    await expect(this.table.locator('tbody td').filter({ hasText: cellText })).toBeVisible();
  }

  async assertRowCount(expectedCount: number): Promise<void> {
    await expect(this.table.locator('tbody tr')).toHaveCount(expectedCount);
  }
}

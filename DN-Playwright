### Step 3.12 — Generate `support/hooks.ts`

```typescript
// e2e/support/hooks.ts
import { Before, After, BeforeAll, AfterAll, Status } from '@cucumber/cucumber';
import { chromium } from '@playwright/test';
import { CustomWorld } from './world';
import { AuthHelper } from '../helpers/auth.helper';
import { WaitHelper } from '../helpers/wait.helper';
import { FormHelper } from '../helpers/form.helper';
import { ApiHelper } from '../helpers/api.helper';

BeforeAll(async function () {
  // Global setup if needed (seed DB, reset state, etc.)
});

Before(async function (this: CustomWorld) {
  this.browser = await chromium.launch({ headless: process.env.HEADED !== 'true' });
  this.context = await this.browser.newContext({
    baseURL: process.env.APP_URL || 'http://localhost:4200',
    recordVideo: { dir: 'e2e/reports/videos/' },
  });
  this.page = await this.context.newPage();

  // Wire up helpers
  this.auth = new AuthHelper(this.page);
  this.wait = new WaitHelper(this.page);
  this.form = new FormHelper(this.page);
  this.api = new ApiHelper(this.page);
});

After(async function (this: CustomWorld, scenario) {
  if (scenario.result?.status === Status.FAILED) {
    const screenshot = await this.page.screenshot({ fullPage: true });
    this.attach(screenshot, 'image/png');

    const videoPath = await this.page.video()?.path();
    if (videoPath) this.attach(`Video: ${videoPath}`, 'text/plain');
  }

  await this.page.close();
  await this.context.close();
  await this.browser.close();
});

AfterAll(async function () {
  // Global teardown
});
```


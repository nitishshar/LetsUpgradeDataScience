### Step 3.4 — Generate Helper: `base.page.ts`

```typescript
// e2e/helpers/base.page.ts
import { Page, Locator, expect } from '@playwright/test';

export abstract class BasePage {
  constructor(protected page: Page) {}

  /** Navigate to a path relative to baseURL */
  async navigateTo(path: string): Promise<void> {
    await this.page.goto(path);
    await this.page.waitForLoadState('networkidle');
  }

  /** Get element by data-testid attribute (preferred selector strategy) */
  byTestId(testId: string): Locator {
    return this.page.locator(`[data-testid="${testId}"]`);
  }

  /** Get element by aria-label */
  byAriaLabel(label: string): Locator {
    return this.page.getByRole('button', { name: label });
  }

  /** Click with automatic wait for element to be stable */
  async safeClick(locator: Locator): Promise<void> {
    await locator.waitFor({ state: 'visible' });
    await locator.scrollIntoViewIfNeeded();
    await locator.click();
  }

  /** Fill input with clear-first safety */
  async safeFill(locator: Locator, value: string): Promise<void> {
    await locator.waitFor({ state: 'visible' });
    await locator.clear();
    await locator.fill(value);
  }

  /** Wait for Angular to stabilize (no pending HTTP or timers) */
  async waitForAngular(): Promise<void> {
    await this.page.waitForFunction(() => {
      const el = document.querySelector('[ng-version]');
      if (!el) return true;
      // @ts-ignore
      const testability = window.getAllAngularTestabilities?.();
      return testability?.every((t: any) => t.isStable()) ?? true;
    });
  }

  async assertVisible(locator: Locator, message?: string): Promise<void> {
    await expect(locator, message).toBeVisible();
  }

  async assertText(locator: Locator, expected: string): Promise<void> {
    await expect(locator).toHaveText(expected);
  }

  async assertURL(pattern: string | RegExp): Promise<void> {
    await expect(this.page).toHaveURL(pattern);
  }

  async getPageTitle(): Promise<string> {
    return this.page.title();
  }

  async takeScreenshot(name: string): Promise<void> {
    await this.page.screenshot({
      path: `e2e/reports/screenshots/${name}-${Date.now()}.png`,
      fullPage: true,
    });
  }
}
```

### Step 3.5 — Generate Helper: `wait.helper.ts`

```typescript
// e2e/helpers/wait.helper.ts
import { Page } from '@playwright/test';

export class WaitHelper {
  constructor(private page: Page) {}

  async waitForNetworkIdle(timeout = 5000): Promise<void> {
    await this.page.waitForLoadState('networkidle', { timeout });
  }

  async waitForSpinnerToDisappear(spinnerSelector = '[data-testid="spinner"]'): Promise<void> {
    const spinner = this.page.locator(spinnerSelector);
    try {
      await spinner.waitFor({ state: 'visible', timeout: 2000 });
      await spinner.waitFor({ state: 'hidden', timeout: 15000 });
    } catch {
      // spinner may not appear for fast responses
    }
  }

  async waitForToastToAppear(): Promise<string> {
    const toast = this.page.locator('[data-testid="toast"], .toast, .snack-bar, mat-snack-bar-container');
    await toast.waitFor({ state: 'visible', timeout: 5000 });
    return toast.innerText();
  }

  async waitForAPIResponse(urlPattern: string | RegExp): Promise<any> {
    const response = await this.page.waitForResponse(urlPattern);
    return response.json();
  }

  async waitForRouteChange(expectedPath: string): Promise<void> {
    await this.page.waitForURL(`**${expectedPath}**`);
  }
}
```

### Step 3.6 — Generate Helper: `form.helper.ts`

```typescript
// e2e/helpers/form.helper.ts
import { Page, Locator } from '@playwright/test';
import { BasePage } from './base.page';

export class FormHelper {
  constructor(private page: Page) {}

  async fillInput(label: string, value: string): Promise<void> {
    const input = this.page.getByLabel(label);
    await input.clear();
    await input.fill(value);
    await input.blur();
  }

  async selectDropdown(label: string, optionText: string): Promise<void> {
    const select = this.page.getByLabel(label);
    await select.selectOption({ label: optionText });
  }

  async selectMatDropdown(label: string, optionText: string): Promise<void> {
    await this.page.getByLabel(label).click();
    await this.page.locator('mat-option').filter({ hasText: optionText }).click();
  }

  async checkCheckbox(label: string): Promise<void> {
    const cb = this.page.getByLabel(label);
    if (!(await cb.isChecked())) await cb.check();
  }

  async getValidationError(field: string): Promise<string> {
    const errorEl = this.page.locator(`[data-testid="${field}-error"], mat-error`).first();
    return errorEl.innerText();
  }

  async submitForm(buttonText = 'Submit'): Promise<void> {
    await this.page.getByRole('button', { name: buttonText }).click();
  }

  async assertFieldIsRequired(label: string): Promise<void> {
    const input = this.page.getByLabel(label);
    await input.clear();
    await input.blur();
    const hasError = await this.page.locator('mat-error, .error-message').count();
    if (hasError === 0) throw new Error(`No validation error shown for required field: ${label}`);
  }
}
